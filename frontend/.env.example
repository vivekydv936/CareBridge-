# ─────────────────────────────────────────────────────────────────────────────
# ScriptMD Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# All variables MUST start with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Backend URL ───────────────────────────────────────────────────────────
# Development: Vite proxy handles /api → localhost:5000 (no VITE_API_URL needed)
# Production: Set to your deployed backend URL
VITE_API_URL=http://localhost:5000

# ── App Info ──────────────────────────────────────────────────────────────────
VITE_APP_NAME=ScriptMD
VITE_APP_VERSION=1.0.0
