# ─────────────────────────────────────────────────────────────────────────────
# ScriptMD Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated for multiple origins in production
CLIENT_URL=http://localhost:5173

# ── Email / SMTP (Nodemailer) ─────────────────────────────────────────────────
# Gmail: Enable 2FA then create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-gmail-app-password

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
